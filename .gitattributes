* text=auto

# 跑在 Linux 上的代码强制 LF（避免 Windows 的 CRLF 让 bash 找不到 /usr/bin/env\r）
*.sh         text eol=lf
*.py         text eol=lf
*.service    text eol=lf
*.timer      text eol=lf
*.json       text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
rc.local     text eol=lf

# 二进制不动
*.png  binary
*.jpg  binary
*.ttf  binary
*.ttc  binary
